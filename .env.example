# --- LLM (Groq) ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=4000

# --- Web search (Tavily) ---
TAVILY_API_KEY=your-tavily-api-key
TAVILY_MAX_CONCURRENT_SEARCHES=5
TAVILY_SEARCH_TIMEOUT_SECONDS=30
TAVILY_MAX_RETRIES=2

# --- Web search fallback (SerpAPI, optional) ---
SERPAPI_API_KEY=

# --- Persistence (Postgres: runs + LangGraph checkpoints) ---
# Leave empty to run without persistence (in-memory checkpoints).
DATABASE_URL=postgresql://researcher:changeme@localhost:5432/research_db

# --- API security ---
# Comma-separated list of accepted X-API-Key values. Empty = auth disabled (local dev).
API_KEYS=
# Comma-separated allowed CORS origins.
CORS_ORIGINS=http://localhost:3000

# --- Application ---
APP_NAME=Research Agent
APP_VERSION=1.0.0
APP_DEBUG=true
LOG_LEVEL=INFO

# --- Research ---
RESEARCH_OUTPUT_DIR=./research_outputs
RESEARCH_TIMEOUT_MINUTES=10

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Optional: Pipelock LLM-traffic proxy (local dev tooling only) ---
# When set, all Groq API calls are routed through this forward proxy.
PIPELOCK_PROXY_URL=
# Set to true ONLY for a local TLS-terminating proxy; disables cert verification.
PIPELOCK_PROXY_INSECURE=false
