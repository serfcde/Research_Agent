# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MODEL_FALLBACK=gpt-4-turbo-preview

# Tavily API Configuration
TAVILY_API_KEY=your_tavily_api_key_here

# SerpAPI Configuration (fallback)
SERPAPI_API_KEY=your_serpapi_api_key_here

# Application Configuration
APP_NAME=Research Agent
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
TAVILY_MAX_CONCURRENT_SEARCHES=5
TAVILY_SEARCH_TIMEOUT_SECONDS=30
TAVILY_MAX_RETRIES=2

# LLM Configuration
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=4000

# Research Configuration
RESEARCH_OUTPUT_DIR=./research_outputs
RESEARCH_TIMEOUT_MINUTES=10

# Server Configuration
HOST=0.0.0.0
PORT=8000
