{
  "title": "Research Agent",
  "uid": "research-agent",
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Runs completed (range)",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(increase(research_runs_finished_total{status=\"completed\"}[$__range]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Runs failed (range)",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "targets": [
        { "expr": "sum(increase(research_runs_finished_total{status=\"failed\"}[$__range])) or vector(0)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active runs",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "research_active_runs", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Replan rate",
      "description": "Share of finished runs where the critic sent the graph back to the planner",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(increase(research_replans_total[$__range])) / sum(increase(research_runs_finished_total[$__range]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 0 }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "LLM spend (range)",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "targets": [
        { "expr": "sum(increase(research_llm_cost_usd_total[$__range]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "SSE subscribers",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "targets": [{ "expr": "research_sse_subscribers", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Node duration p95 (s)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(research_node_duration_seconds_bucket[5m])) by (le, node))",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Run duration p50 / p95 (s)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(research_run_duration_seconds_bucket[10m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(research_run_duration_seconds_bucket[10m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "LLM tokens / min",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(research_llm_tokens_total[5m])) by (type) * 60",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Runs finished / min by status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(research_runs_finished_total[5m])) by (status) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
